# Django Settings
SECRET_KEY=your-secret-key-here-for-testing
ALLOWED_HOSTS=localhost,127.0.0.1
DEBUG=True
DJANGO_SETTINGS_MODULE=clinic_project.settings

# Database Configuration (MySQL)
DB_ENGINE=django.db.backends.mysql
DB_NAME=clinic_db
DB_USER=root
DB_PASSWORD=Jenkins_13
DB_HOST=localhost
DB_PORT=3306

# ============================================================
# EMAIL CONFIGURATION
# ============================================================
# Development: Use console backend (prints to console)
# Production: Use Gmail SMTP or transactional service

# Console backend (development - prints to terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Gmail SMTP backend (production)
# Uncomment the line below and comment out EMAIL_BACKEND above
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Email SMTP settings (for Gmail or other providers)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
SITE_URL=http://localhost:8000

# ============================================================
# CELERY & TASK SCHEDULING CONFIGURATION
# ============================================================
# Redis is used as both message broker and result backend
# Install Redis: brew install redis (Mac) or docker pull redis

# Celery Broker URL (Redis)
CELERY_BROKER_URL=redis://localhost:6379/0

# Celery Result Backend (Redis)
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================================
# GOOGLE CALENDAR CONFIGURATION (existing)
# ============================================================
GOOGLE_OAUTH_CREDENTIALS_FILE=google_oauth_credentials.json

# ============================================================
# GOOGLE OAUTH — PATIENT SIGN-IN
# ============================================================
# Obtain credentials from Google Cloud Console:
# https://console.cloud.google.com/

# Google OAuth 2.0 Client ID (from Google Cloud Console)
GOOGLE_OAUTH_CLIENT_ID=1037934508679-lgmm56eg0ac0sj0ld4paqg7525gi8n0c.apps.googleusercontent.com

# Google OAuth 2.0 Client Secret (from Google Cloud Console)
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret-here

# Google OAuth Redirect URI (must match Google Cloud Console settings)
# Development (local):
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:8000/accounts/google/login/callback/

# Production (replace with your domain):
# GOOGLE_OAUTH_CALLBACK_URL=https://yourdomain.com/accounts/google/login/callback/
